    "migrate": "node --experimental-strip-types src/db/migrate.ts"
  },
  "dependencies": {
    "@shop/shared": "*",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}

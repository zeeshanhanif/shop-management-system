# Copy to .env and fill in. NEVER commit the real .env (see ADR-008 / §8 Security).

# --- Database (Supabase Postgres, via the Supavisor pooler — see ADR-003) ---
# Use the SUPABASE TRANSACTION-MODE POOLER endpoint (port 6543), not the direct
# database connection (5432) — Cloud Run's serverless fan-out needs the pooler.
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string → "Transaction".
DATABASE_URL=postgresql://postgres.<ref>:password@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# --- Stripe (ADR-005) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email provider (notifications, ADR-004) ---
EMAIL_API_KEY=
EMAIL_FROM="Shop <orders@example.com>"

# --- Auth (ADR-007) ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Async queue (Cloud Tasks, ADR-004) ---
CLOUD_TASKS_QUEUE=projects/PROJECT/locations/REGION/queues/jobs
# Public URL Cloud Tasks pushes back to (this API):
API_PUBLIC_URL=https://api.example.com

# Minutes a card-checkout stock reservation is held before the sweep releases it (ADR-006)
RESERVATION_TIMEOUT_MINUTES=30

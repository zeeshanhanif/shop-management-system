# Copy to .env and fill in. NEVER commit the real .env (see ADR-008 / §8 Security).

# --- Database (managed Postgres, via connection pooler — see ADR-003) ---
# Point this at the POOLER endpoint, not the database directly.
DATABASE_URL=postgresql://user:password@pooler-host:5432/shop?sslmode=require

# --- Stripe (ADR-005) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email provider (notifications, ADR-004) ---
EMAIL_API_KEY=
EMAIL_FROM="Shop <orders@example.com>"

# --- Auth (ADR-007) ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Async queue (Cloud Tasks, ADR-004) ---
CLOUD_TASKS_QUEUE=projects/PROJECT/locations/REGION/queues/jobs
# Public URL Cloud Tasks pushes back to (this API):
API_PUBLIC_URL=https://api.example.com

# Minutes a card-checkout stock reservation is held before the sweep releases it (ADR-006)
RESERVATION_TIMEOUT_MINUTES=30
